{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "${description}",
  "authors": [
    "${authors}"
  ],
  "contact": {
    "sources": "${sources}",
    "issues": "${sources}/issues"
  },
  "license": "${license}",
  "icon": "${id}.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.timtaran.interactivemc.fabric.InteractiveMCFabric"
    ],
    "modmenu": [
      "net.timtaran.interactivemc.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    "interactivemc.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "architectury": ">=${architectury_api_version}",
    "vivecraft": ">=${vivecraft_version}",
    "yet_another_config_lib_v3": ">=${yacl_version}",
    "velthoric": ">=${velthoric_version}",
    "fabric-api": "*"
  }
}
